---
import { useTranslations } from "../i18n/ui";

interface Props {
  lang: "zh" | "en";
  title: string;
}

const { lang, title } = Astro.props;
const t = useTranslations(lang);

const switchTo = lang === "zh" ? "en" : "zh";
const currentPath = Astro.url.pathname;
const targetPath = currentPath.replace(/^\/(zh|en)/, `/${switchTo}`);

const homePath = `/${lang}/`;
const aboutPath = `/${lang}/about`;
const blogPath = `/${lang}/blog`;

const isHome = currentPath === homePath;
const isAbout = currentPath === aboutPath;
const isBlog = currentPath === blogPath;
---

<html lang={lang === "zh" ? "zh-Hant" : "en"}>
  <head>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>

    <script is:inline>
      (() => {
        try {
          const stored = localStorage.getItem("theme");
          const systemDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          const theme = stored || (systemDark ? "dark" : "light");
          document.documentElement.dataset.theme = theme;
        } catch {
          document.documentElement.dataset.theme = "light";
        }
      })();
    </script>

    <style>
      :root {
        --bg: #f7f8fb;
        --bg-accent-1: #eef4ff;
        --bg-accent-2: #fdf2f8;
        --surface: rgba(255, 255, 255, 0.78);
        --surface-strong: rgba(255, 255, 255, 0.82);
        --surface-soft: rgba(255, 255, 255, 0.88);
        --text: #111827;
        --text-soft: #374151;
        --muted: #6b7280;
        --border: rgba(17, 24, 39, 0.08);
        --link: #2563eb;
        --link-hover: #1d4ed8;
        --active-bg: #e8efff;
        --nav-bg: rgba(255, 255, 255, 0.7);
        --nav-link: #374151;
        --nav-link-hover-bg: #eef4ff;
        --nav-link-hover-text: #111827;
        --button-bg: #111827;
        --button-text: #ffffff;
        --button-hover-bg: #1f2937;
        --back-link-text: #111827;
        --shadow: 0 10px 30px rgba(15, 23, 42, 0.06);
        --card-hover-shadow: 0 12px 30px rgba(15, 23, 42, 0.05);
      }

      :root[data-theme="dark"] {
        --bg: #0b1220;
        --bg-accent-1: rgba(37, 99, 235, 0.12);
        --bg-accent-2: rgba(168, 85, 247, 0.10);
        --surface: rgba(17, 24, 39, 0.72);
        --surface-strong: rgba(17, 24, 39, 0.82);
        --surface-soft: rgba(17, 24, 39, 0.88);
        --text: #f9fafb;
        --text-soft: #d1d5db;
        --muted: #94a3b8;
        --border: rgba(148, 163, 184, 0.18);
        --link: #60a5fa;
        --link-hover: #93c5fd;
        --active-bg: rgba(96, 165, 250, 0.16);
        --nav-bg: rgba(15, 23, 42, 0.72);
        --nav-link: #e5e7eb;
        --nav-link-hover-bg: rgba(96, 165, 250, 0.12);
        --nav-link-hover-text: #ffffff;
        --button-bg: #e5e7eb;
        --button-text: #111827;
        --button-hover-bg: #ffffff;
        --back-link-text: #f9fafb;
        --shadow: 0 10px 30px rgba(0, 0, 0, 0.28);
        --card-hover-shadow: 0 12px 30px rgba(0, 0, 0, 0.22);
      }

      * {
        box-sizing: border-box;
      }

      html {
        color-scheme: light;
        background:
          radial-gradient(circle at top left, var(--bg-accent-1), transparent 30%),
          radial-gradient(circle at top right, var(--bg-accent-2), transparent 28%),
          var(--bg);
      }

      html[data-theme="dark"] {
        color-scheme: dark;
      }

      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: var(--text);
        line-height: 1.75;
        padding: 24px 16px 64px;
        background: transparent;
        transition: background 0.25s ease, color 0.25s ease;
      }

      .container {
        max-width: 1040px;
        margin: 0 auto;
      }

      .site-header {
        position: sticky;
        top: 16px;
        z-index: 10;
        margin-bottom: 40px;
      }

      .nav-shell {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
        padding: 14px 18px;
        border: 1px solid var(--border);
        border-radius: 999px;
        background: var(--nav-bg);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        box-shadow: var(--shadow);
      }

      nav {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      a {
        color: var(--link);
        text-decoration: none;
        transition: all 0.2s ease;
      }

      a:hover {
        color: var(--link-hover);
      }

      nav a {
        padding: 8px 14px;
        border-radius: 999px;
        color: var(--nav-link);
      }

      nav a:hover {
        background: var(--nav-link-hover-bg);
        color: var(--nav-link-hover-text);
      }

      .active {
        background: var(--active-bg);
        color: var(--text);
        font-weight: 600;
      }

      .header-actions {
        display: flex;
        align-items: center;
        gap: 10px;
        flex-wrap: wrap;
      }

      .theme-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        border: 1px solid var(--border);
        border-radius: 999px;
        background: var(--surface);
        color: var(--text);
        cursor: pointer;
        box-shadow: var(--shadow);
        transition: transform 0.2s ease, background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
      }

      .theme-toggle:hover {
        transform: translateY(-1px);
      }

      .lang-switch {
        padding: 8px 14px;
        border-radius: 999px;
        background: var(--button-bg);
        color: var(--button-text);
        font-weight: 600;
      }

      .lang-switch:hover {
        background: var(--button-hover-bg);
        color: var(--button-text);
      }

      main {
        min-height: 60vh;
      }

      h1,
      h2,
      h3 {
        line-height: 1.2;
        letter-spacing: -0.03em;
        margin-top: 0;
        color: var(--text);
      }

      h1 {
        font-size: clamp(2.2rem, 5vw, 4.2rem);
        margin-bottom: 16px;
      }

      h2 {
        font-size: 1.55rem;
        margin-bottom: 8px;
      }

      p {
        margin: 0 0 16px;
        color: var(--text-soft);
      }

      small {
        color: var(--muted);
      }

      .page-head {
        max-width: 620px;
        margin-bottom: 24px;
      }

      ul {
        list-style: none;
        padding: 0;
        margin: 24px 0 0;
      }

      li {
        margin-bottom: 20px;
        padding: 22px;
        border: 1px solid var(--border);
        border-radius: 18px;
        background: var(--surface);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
      }

      li:hover {
        transform: translateY(-2px);
        border-color: rgba(37, 99, 235, 0.18);
        box-shadow: var(--card-hover-shadow);
      }

      article {
        max-width: 760px;
        padding: 32px;
        border: 1px solid var(--border);
        border-radius: 24px;
        background: var(--surface-strong);
        box-shadow: var(--shadow);
      }

      article p {
        margin: 16px 0;
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-top: 28px;
        padding: 10px 16px;
        border-radius: 999px;
        background: var(--surface-soft);
        border: 1px solid var(--border);
        color: var(--back-link-text);
        font-weight: 600;
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.05);
      }

      .back-link:hover {
        background: var(--nav-link-hover-bg);
        color: var(--back-link-text);
        transform: translateY(-1px);
      }

      @media (max-width: 720px) {
        body {
          padding: 16px 12px 40px;
        }

        .site-header {
          top: 12px;
          margin-bottom: 28px;
        }

        .nav-shell {
          border-radius: 24px;
          padding: 14px;
        }

        article {
          padding: 22px 18px;
          border-radius: 18px;
        }
      }
    </style>
  </head>

  <body>
    <div class="container">
      <header class="site-header">
        <div class="nav-shell">
          <nav>
            <a href={homePath} class:list={[isHome && "active"]}>{t("home")}</a>
            <a href={aboutPath} class:list={[isAbout && "active"]}>{t("about")}</a>
            <a href={blogPath} class:list={[isBlog && "active"]}>{t("blog")}</a>
          </nav>

          <div class="header-actions">
            <button
              class="theme-toggle"
              id="theme-toggle"
              type="button"
              aria-label="Toggle theme"
            >
              🌓
            </button>

            <a class="lang-switch" href={targetPath}>{t("switchLang")}</a>
          </div>
        </div>
      </header>

      <main>
        <slot />
      </main>
    </div>

    <script is:inline>
      (() => {
        const initThemeToggle = () => {
          const button = document.getElementById("theme-toggle");
          if (!button || button.dataset.bound === "true") return;

          button.dataset.bound = "true";

          const updateLabel = () => {
            const theme = document.documentElement.dataset.theme || "light";
            button.setAttribute(
              "aria-label",
              theme === "dark" ? "Switch to light mode" : "Switch to dark mode"
            );
          };

          button.addEventListener("click", () => {
            const current = document.documentElement.dataset.theme || "light";
            const next = current === "dark" ? "light" : "dark";
            document.documentElement.dataset.theme = next;
            localStorage.setItem("theme", next);
            updateLabel();
          });

          updateLabel();
        };

        initThemeToggle();
        document.addEventListener("astro:page-load", initThemeToggle);
      })();
    </script>
  </body>
</html>
