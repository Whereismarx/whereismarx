---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations } from "../../i18n/ui";

const t = useTranslations("zh");
---

<BaseLayout lang="zh" title={t("about")}>
  <section class="page-head">
    <h1>{t("about")}</h1>
    <p>{t("aboutIntro")}</p>
  </section>

  <section class="home-hero">
    <div class="home-copy-wrap">
      <div class="home-copy">
        <p>
          This is where I share articles, learning notes, and ideas that are still taking shape.
        </p>
      </div>
    </div>

    <div class="home-media">
      <div class="image-frame">
        <img src="/images/About.jpg" alt="About image" />
      </div>
    </div>
  </section>

  <style>
    .home-head {
      margin-bottom: 32px;
    }

    .home-hero {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(320px, 440px);
      align-items: start;
      gap: 40px;
    }

    .home-copy-wrap {
      min-width: 0;
    }

    .home-copy {
      max-width: 460px;
      font-size: 1.05rem;
    }

    .hero-actions {
      display: flex;
      gap: 14px;
      flex-wrap: wrap;
      margin-top: 28px;
    }


    .home-media {
      width: 100%;
      justify-self: end;
    }

    .image-frame {
      width: 100%;
      max-width: 440px;
      aspect-ratio: 4 / 5;
      border-radius: 28px;
      overflow: hidden;
      box-shadow: 0 20px 50px rgba(15, 23, 42, 0.12);
      background: rgba(255, 255, 255, 0.6);
    }

    .image-frame img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    @media (max-width: 840px) {
      .home-hero {
        grid-template-columns: 1fr;
        gap: 28px;
      }

      .home-media {
        order: -1;
        justify-self: start;
        width: 100%;
      }

      .image-frame {
        max-width: 100%;
        aspect-ratio: 16 / 10;
      }

      .home-copy {
        max-width: 100%;
      }
    }
  </style>
</BaseLayout>
