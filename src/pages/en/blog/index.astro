---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { useTranslations } from "../../../i18n/ui";
import { blogPosts } from "../../../data/blog";

const t = useTranslations("en");
const posts = blogPosts.en;
---

<BaseLayout lang="en" title={t("blog")}>
  <section class="page-head">
    <h1>{t("blog")}</h1>
    <p>{t("blogIntro")}</p>
  </section>

  <ul class="post-list">
    {posts.map((post) => (
      <li class="post-card">
        <a class="post-link" href={`/en/blog/${post.slug}`}>
          <div class="post-content">
            <h2>{post.title}</h2>
            <p>{post.description}</p>
            <p><small>{post.date}</small></p>
          </div>

          <div class="post-thumb">
            <img src={post.image} alt={post.title} />
          </div>
        </a>
      </li>
    ))}
  </ul>

  <style>
    .post-list {
      margin-top: 24px;
    }

    .post-card {
      padding: 0;
      overflow: hidden;
    }

    .post-link {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 180px;
      gap: 20px;
      align-items: center;
      padding: 22px;
      color: inherit;
    }

    .post-link:hover {
      color: inherit;
    }

    .post-content h2 {
      margin-bottom: 10px;
    }

    .post-content p:last-child {
      margin-bottom: 0;
    }

    .post-thumb {
      width: 100%;
      aspect-ratio: 4 / 3;
      border-radius: 16px;
      overflow: hidden;
      background: rgba(255, 255, 255, 0.65);
    }

    .post-thumb img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }

    @media (max-width: 720px) {
      .post-link {
        grid-template-columns: 1fr;
      }

      .post-thumb {
        order: -1;
      }
    }
  </style>
</BaseLayout>
